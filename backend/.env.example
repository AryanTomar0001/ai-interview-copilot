# FastAPI Backend Environment Variables

# Groq API Key for Speech-to-Text (Whisper)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key for Question Generation & Evaluation
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB Connection (if used)
MONGODB_URI=mongodb://localhost:27017/ai_interview

# Other API Keys (if needed)
# OPENAI_API_KEY=your_openai_key_here
